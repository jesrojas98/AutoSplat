# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Backend NestJS (para reportar progreso) ───────────────────────────────────
BACKEND_URL=http://localhost:3000

# ── Worker identity ───────────────────────────────────────────────────────────
WORKER_ID=local-worker-1

# ── Pipeline ──────────────────────────────────────────────────────────────────
# Directorio temporal para procesamiento (se limpia después de cada job)
WORK_DIR=/tmp/autosplat_worker

# Nombre del bucket de Supabase Storage donde se suben los modelos
STORAGE_BUCKET=models

# Iteraciones de entrenamiento (reducir para demos rápidos en CPU)
# CPU (Intel):     3000–5000  (~30-60 min por escena)
# Apple Silicon:   7000–10000 (~10-20 min por escena con MPS)
# GPU NVIDIA:      30000      (~5-10 min)
TRAIN_MAX_ITERATIONS=7000

# Polling: cada cuántos segundos revisar nuevos jobs
POLL_INTERVAL=30
